<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FoodNutritionApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorSecondary">@color/accent_color</item>

        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="cardViewStyle">@style/CardViewLightStyle</item>
    </style>

    <!-- Same style name, dark background -->
    <style name="CardViewLightStyle" parent="CardView">
        <item name="cardBackgroundColor">@color/card_background_dark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

</resources>
